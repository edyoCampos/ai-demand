# LLM Configuration
LLM_PROVIDER=anthropic # Options: anthropic, openai, ollama, deepseek, groq, mistral, together, gemini
LLM_MODEL=claude-3-5-sonnet-20241022

# Generic API Key
LLM_API_KEY=your_api_key_here

# Provider-Specific Keys (Recommended)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...
DEEPSEEK_API_KEY=sk-...
GROQ_API_KEY=gsk_...
MISTRAL_API_KEY=...
GEMINI_API_KEY=...

# Optional: Overrides and Local Models
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_TIMEOUT=60000

PORT=3000
